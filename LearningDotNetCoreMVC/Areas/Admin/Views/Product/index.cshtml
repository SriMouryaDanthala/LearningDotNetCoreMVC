@model List<Product>

<h1>Products</h1>

<table class="table table-striped">
    <thead>
    <th>Id</th>
    <th>Name</th>
    <th>Author</th>
    <th>Description</th>
    <th>ISBN</th>
    <th>Price</th>
    <th>Price for 50</th>
    <th>Price for 100</th>
    <th></th>
    </thead>
    <tbody>
    @foreach(Product product in Model)
    {
        <tr>
            <td>@product.Id</td>
            <td>@product.Name</td>
            <td>@product.Author</td>
            <td>@product.Description</td>
            <td>@product.ISBN</td>
            <td>@product.Price</td>
            <td>@product.PriceForFifty</td>
            <td>@product.PriceForHundred</td>
            <td>
                <div class="d-flex gap-2">
                    <a asp-area="Admin" asp-controller="Product" asp-action="Upsert" asp-route-id="@product.Id" class="btn btn-primary text-light flex-fill">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
            
                    <a asp-area="Admin"  asp-controller="Product" asp-action="Delete" asp-route-id="@product.Id" class="btn btn-danger text-light flex-fill">
                        <i class="bi bi-trash3"></i> Delete
                    </a>
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>
<a asp-controller="Product" asp-action="Upsert" class="btn btn-secondary text-light">
    <i class="bi bi-plus"></i> Create New Product
</a>
