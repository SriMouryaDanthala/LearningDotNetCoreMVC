@model Category
<h1>Create new Category</h1>
<form method="post">
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input type="text" class="form-control" id="Name" name="Name" placeholder="Enter category name">
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="DisplayOrder" class="form-label"></label>
        <input type="number" class="form-control" id="DisplayOrder" name="DisplayOrder" min="0" max="100" step="1" value="0">
        <span asp-validation-for="DisplayOrder" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
    <a class="btn btn-secondary" asp-controller="Category" asp-action="Index">
        Return to Categories
    </a>
</form>