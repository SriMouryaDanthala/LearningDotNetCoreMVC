@model List<Category>

<h1>Categories</h1>

<table class="table table-striped">
    <thead>
        <th>ID</th>
        <th>Name</th>
        <th>Display Order</th>
        <th></th>
    </thead>
    <tbody>
        @foreach(Category category in Model)
        {
            <tr>
                <td>@category.ID</td>
                <td>@category.Name</td>
                <td>@category.DisplayOrder</td>
                <td>
                    <div class="d-flex gap-2">
                        <a asp-area="Admin" asp-controller="Category" asp-action="Edit" asp-route-id="@category.ID" class="btn btn-primary text-light flex-fill">
                                <i class="bi bi-pencil"></i> Edit
                            </a>

                            <a asp-area="Admin"  asp-controller="Category" asp-action="Delete" asp-route-id="@category.ID" class="btn btn-danger text-light flex-fill">
                                <i class="bi bi-trash3"></i> Delete
                            </a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-controller="Category" asp-action="Create" class="btn btn-secondary text-light">
    <i class="bi bi-plus"></i> Create New Category
</a>
